# bots/etf_rotation_v1/.env.example
# Copy to .env in this folder for local runs. .env is gitignored.

# ── Public.com ───────────────────────────────────────────────────────────────
PUBLIC_SECRET=your_public_api_secret

# ── League Supabase project ──────────────────────────────────────────────────
LEAGUE_SUPABASE_URL=https://YOUR_LEAGUE_PROJECT.supabase.co
LEAGUE_SUPABASE_KEY=YOUR_LEAGUE_SERVICE_ROLE_KEY
LEAGUE_BOT_ID=etf_rotation_v1

# ── Strategy / sizing (optional — defaults shown) ────────────────────────────
ETF_PAPER_CAPITAL=1000
ETF_BARS_PERIOD=YEAR
