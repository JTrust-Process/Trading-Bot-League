# bots/agent_research_v1/.env.example
# Copy to .env locally. .env is gitignored.

# League Supabase project (reads context, writes events/signals/approvals)
LEAGUE_SUPABASE_URL=https://YOUR_LEAGUE_PROJECT.supabase.co
LEAGUE_SUPABASE_KEY=YOUR_LEAGUE_SERVICE_ROLE_KEY
LEAGUE_BOT_ID=agent_research_v1

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — defaults shown
AGENT_MODEL=claude-haiku-4-5-20251001
AGENT_MAX_PROPOSALS=3
