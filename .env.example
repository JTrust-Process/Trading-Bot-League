# League of Trading Bots — environment variables
#
# This is the TEMPLATE. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit it.
#
# All values below are NAMES ONLY — there are no real secrets in this file.

# ── League Supabase project (the new, third Supabase project) ────────────────
# Created on a separate Supabase account because the primary one is at the
# 2-project free-tier limit.
LEAGUE_SUPABASE_URL=https://YOUR_LEAGUE_PROJECT.supabase.co
LEAGUE_SUPABASE_KEY=YOUR_LEAGUE_SERVICE_ROLE_KEY

# ── Per-bot identity ─────────────────────────────────────────────────────────
# Each bot process sets this to its own bot_id from bot_registry.
# Examples:
#   stock_momentum_v1
#   crypto_ema_atr_v1
#   etf_rotation_v1
LEAGUE_BOT_ID=

# ── Global kill switch (operator-only) ───────────────────────────────────────
# Set to "1" to refuse every order across the whole League. Cleared at the
# next workflow run by removing/setting back to "0". Read each cycle, no
# restart needed. The per-bot kill switch lives in bot_registry.status.
LEAGUE_KILL=0

# ── Discord (optional, only used by the league_health workflow later) ────────
LEAGUE_DISCORD_WEBHOOK_URL=
